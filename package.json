{
  "name": "chatgpt-desktop-linux",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Source-only ChatGPT DMG to Linux compatibility builder",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "app": "node src/cli.mjs app",
    "build": "node src/cli.mjs build",
    "check": "node scripts/check.mjs",
    "inspect": "node src/cli.mjs inspect",
    "package": "node src/cli.mjs package build/app",
    "test": "node --test test/*.test.mjs"
  },
  "dependencies": {
    "@electron/asar": "4.2.0",
    "@electron/rebuild": "4.2.0"
  }
}
